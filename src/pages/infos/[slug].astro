---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  // Emit the physical file as {slug}.html.html so Cloudflare Pages' clean-URL
  // rule serves the legacy permalink /infos/{slug}.html with a 200 (not a 308
  // redirect to an extensionless URL). Preserves the old URLs byte-for-byte.
  return posts.map((post) => ({
    params: { slug: `${post.data.slug}.html` },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const d = post.data;

// --- heading ids + table of contents ---------------------------------------
function slugify(s: string) {
  return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 60);
}
const toc: { id: string; text: string; level: number }[] = [];
const usedIds = new Set<string>();
const html = d.html.replace(/<h([23])([^>]*)>([\s\S]*?)<\/h\1>/g, (m, lvl, attrs, inner) => {
  const text = inner.replace(/<[^>]+>/g, '').trim();
  if (!text) return m;
  let id = slugify(text) || `section-${toc.length + 1}`;
  let base = id, k = 2;
  while (usedIds.has(id)) id = `${base}-${k++}`;
  usedIds.add(id);
  toc.push({ id, text, level: Number(lvl) });
  return `<h${lvl}${attrs} id="${id}">${inner}</h${lvl}>`;
});
const showToc = toc.filter((t) => t.level === 2).length >= 3;

// --- related ----------------------------------------------------------------
const sorted = posts.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
const idx = sorted.findIndex((p) => p.data.slug === d.slug);
const related = [];
for (let i = 1; i <= sorted.length && related.length < 3; i++) {
  const cand = sorted[(idx + i) % sorted.length];
  if (cand.data.slug !== d.slug) related.push(cand);
}

const canonical = `https://www.fr-business.net/infos/${d.slug}.html`;
const dateFr = new Date(d.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const modFr = new Date(d.modified).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const imgAbs = d.image ? (d.image.startsWith('http') ? d.image : 'https://www.fr-business.net' + d.image) : undefined;

const jsonld: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: d.title,
    description: d.excerpt,
    image: imgAbs ? [imgAbs] : undefined,
    datePublished: d.date,
    dateModified: d.modified,
    inLanguage: 'fr-FR',
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    author: { '@type': 'Organization', name: 'Fr-business.net', url: 'https://www.fr-business.net/' },
    publisher: {
      '@type': 'Organization', name: 'Fr-business.net',
      logo: { '@type': 'ImageObject', url: 'https://www.fr-business.net/logo.png' },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.fr-business.net/' },
      { '@type': 'ListItem', position: 2, name: 'Infos', item: 'https://www.fr-business.net/articles' },
      { '@type': 'ListItem', position: 3, name: d.title, item: canonical },
    ],
  },
];
if (d.faq && d.faq.length) {
  jsonld.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({
      '@type': 'Question', name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---
<Base title={d.title} description={d.excerpt} image={d.image} type="article" canonical={canonical} jsonld={jsonld}>
  <div class="progress" id="progress"></div>

  <article class="post">
    <header class="post__hero">
      <div class="wrap">
        <nav class="crumb reveal in" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a><span>/</span><a href="/articles">Infos</a>
        </nav>
        <span class="pill reveal in">Infos</span>
        <h1 class="post__title reveal in" data-d="1">{d.title}</h1>
        <div class="post__meta reveal in" data-d="2">
          <span>Publié le <strong>{dateFr}</strong></span>
          <span class="sep">•</span>
          <span>{d.readingTime} min de lecture</span>
          {d.modified && d.modified.slice(0,10) !== d.date.slice(0,10) && (
            <><span class="sep">•</span><span>Mis à jour le <strong>{modFr}</strong></span></>
          )}
        </div>
      </div>

      {d.image && (
        <div class="post__cover reveal in" data-d="3">
          <div class="wrap-wide">
            <div class="post__cover-inner" data-parallax>
              <img src={d.image} alt={d.imageAlt || d.title} width="1536" height="1024" loading="eager" fetchpriority="high" />
            </div>
          </div>
        </div>
      )}
    </header>

    <div class="wrap post__body">
      <div class={showToc ? 'post__layout' : ''}>
        {showToc && (
          <aside class="toc" aria-label="Sommaire">
            <div class="toc__inner">
              <p class="eyebrow">Sommaire</p>
              <ul>
                {toc.filter((t) => t.level === 2).map((t) => (
                  <li><a href={`#${t.id}`}>{t.text}</a></li>
                ))}
              </ul>
              <div class="toc__share">
                <span>Partager</span>
                <a class="magnetic" data-strength="0.2" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener" aria-label="Partager sur LinkedIn">in</a>
                <a class="magnetic" data-strength="0.2" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${encodeURIComponent(d.title)}`} target="_blank" rel="noopener" aria-label="Partager sur X">X</a>
                <a class="magnetic" data-strength="0.2" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener" aria-label="Partager sur Facebook">f</a>
              </div>
            </div>
          </aside>
        )}

        <div class="prose reveal" set:html={html} />
      </div>

      {d.faq && d.faq.length > 0 && (
        <section class="post__faq reveal">
          <div class="sec-head"><p class="eyebrow">Questions fréquentes</p><h2>On répond à vos questions</h2></div>
          <div class="faq-list">
            {d.faq.map((f) => (
              <details class="faq"><summary>{f.q}</summary><div class="faq-body" set:html={f.a} /></details>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>

  <!-- related -->
  <section class="wrap-wide" style="margin-top:5rem">
    <div class="sec-head reveal"><p class="eyebrow">À lire ensuite</p><h2>Dans la même veine</h2></div>
    <div class="rel-grid">
      {related.map((p, i) => <ArticleCard post={{ ...p.data }} delay={(i % 3) as number} />)}
    </div>
  </section>

  <script>
    // reading progress
    const bar = document.getElementById('progress');
    const post = document.querySelector('.post__body');
    if (bar && post) {
      const onScroll = () => {
        const r = post.getBoundingClientRect();
        const total = r.height - window.innerHeight;
        const done = Math.min(1, Math.max(0, -r.top / (total || 1)));
        bar.style.width = `${done * 100}%`;
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
    // cover parallax
    const cover = document.querySelector('[data-parallax] img') as HTMLElement | null;
    if (cover && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      window.addEventListener('scroll', () => {
        const y = Math.min(60, window.scrollY * 0.08);
        cover.style.transform = `translateY(${y}px) scale(1.08)`;
      }, { passive: true });
    }
  </script>
</Base>

<style>
  .post__hero { padding-top: 8.5rem; }
  .crumb { display: flex; gap: .5rem; align-items: center; font-size: .88rem; color: var(--ink-3); margin-bottom: 1rem; }
  .crumb a { color: var(--ink-3); transition: color .3s; } .crumb a:hover { color: var(--aqua-800); }
  .post__title { margin: 1rem 0; font-size: clamp(2rem, 1.2rem + 3.4vw, 3.5rem); max-width: 20ch; }
  .post__meta { display: flex; flex-wrap: wrap; gap: .6rem; align-items: center; color: var(--ink-3); font-size: .95rem; }
  .post__meta strong { color: var(--ink-2); }
  .post__meta .sep { color: var(--aqua-500); }
  .post__cover { margin-top: 2.5rem; }
  .post__cover-inner { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-float); aspect-ratio: 16/9; }
  .post__cover-inner img { width: 100%; height: 100%; object-fit: cover; will-change: transform; }

  .post__body { margin-top: 3rem; }
  .post__layout { display: grid; grid-template-columns: 250px 1fr; gap: 3rem; align-items: start; }
  .toc { position: sticky; top: 110px; }
  .toc__inner { padding: 1.4rem 1.5rem; border-radius: var(--radius); background: rgba(255,255,255,.7); border: 1px solid var(--line); box-shadow: var(--shadow-card); backdrop-filter: blur(8px); }
  .toc ul { margin-top: 1rem; display: grid; gap: .6rem; }
  .toc a { font-size: .92rem; color: var(--ink-2); display: block; padding-left: .9rem; border-left: 2px solid var(--line); transition: color .3s, border-color .3s; line-height: 1.35; }
  .toc a:hover, .toc a.active { color: var(--aqua-800); border-color: var(--aqua); }
  .toc__share { margin-top: 1.4rem; padding-top: 1.2rem; border-top: 1px solid var(--line); display: flex; align-items: center; gap: .5rem; font-size: .8rem; color: var(--ink-3); }
  .toc__share a { width: 34px; height: 34px; display: grid; place-items: center; border-radius: 50%; border: 1px solid var(--aqua-200); background: #fff; font-family: var(--font-display); font-weight: 700; font-size: .85rem; color: var(--aqua-800); transition: background .3s, transform .3s; }
  .toc__share a:hover { background: var(--aqua); }

  .prose { max-width: 74ch; }
  .post__faq { max-width: 74ch; margin: 4rem auto 0; }

  .rel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  @media (max-width: 900px) {
    .post__layout { grid-template-columns: 1fr; }
    .toc { position: static; margin-bottom: 2rem; }
    .toc__inner { }
    .rel-grid { grid-template-columns: 1fr; }
  }
</style>
